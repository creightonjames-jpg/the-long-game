# Optional: Supabase multi-user sync (leaderboard + manager dashboard).
# Without these, the game runs fully local (localStorage only).
#
# Setup:
#   1. Create a project at https://supabase.com (free tier is fine)
#   2. Run supabase/schema.sql in the SQL Editor
#   3. Copy this file to .env.local and fill in from Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
